// Title:        Defender XDR — Credential read burst from node on developer host
// Id:           65f62820-1ceb-4d2a-98e6-d2dc5ae78501
// MITRE:        T1552.001, T1552.004, T1005, T1195.002
// Reference:    https://xygeni.io/blog/evm-defi-npm-typosquatting-attack-steals-developer-keys/
// Author:       Jarmi
// Date:         2026-05-07
// Tested on:    Defender XDR — DeviceProcessEvents + DeviceFileEvents
// FP notes:     Tune dev-tooling discovery list (DevicePresence) and exclude known IT
//               automation hosts. Burst threshold 3 distinct files per InitiatingProcessId
//               in 60s window is conservative; lower for higher-fidelity environments.
//
// Logic: identify devices with Hardhat / Foundry / Brownie installed, then look for
//        node-family processes reading >=3 distinct dev-secret files in 60s.

let LookbackHours = 24h;
let DevTooling =
    DeviceFileEvents
    | where Timestamp > ago(7d)
    | where FileName in~ ("hardhat.config.js","hardhat.config.ts","foundry.toml","brownie-config.yaml")
        or FolderPath has_any ("\\.foundry\\keystores", "/.foundry/keystores",
                               "\\.brownie\\accounts", "/.brownie/accounts")
    | summarize by DeviceId, DeviceName;
let SecretPaths = dynamic([
    "/.ssh/id_", "\\.ssh\\id_",
    "/.aws/credentials", "\\.aws\\credentials",
    "/.aws/config", "\\.aws\\config",
    "/.npmrc", "\\.npmrc",
    "/.foundry/keystores", "\\.foundry\\keystores",
    "/.ethereum/keystore", "\\.ethereum\\keystore",
    "/.brownie/accounts", "\\.brownie\\accounts",
    "/.git-credentials", "\\.git-credentials"
]);
DeviceFileEvents
| where Timestamp > ago(LookbackHours)
| where ActionType in~ ("FileAccessed","FileRead","FileOpen","FileCreated","FileModified")
| where InitiatingProcessFileName in~ ("node.exe","node","ts-node","ts-node.exe","nodejs")
| where FolderPath has_any (SecretPaths)
        or FileName endswith ".env"
        or FileName startswith ".env."
| join kind=inner DevTooling on DeviceId
| summarize
    DistinctFiles = dcount(strcat(FolderPath,"/",FileName)),
    SamplePaths   = make_set(strcat(FolderPath,"/",FileName), 25),
    StartTime     = min(Timestamp),
    EndTime       = max(Timestamp)
    by DeviceId, DeviceName, InitiatingProcessId, InitiatingProcessFileName,
       InitiatingProcessAccountName, InitiatingProcessCommandLine,
       bin(Timestamp, 1m)
| where DistinctFiles >= 3
| where datetime_diff('second', EndTime, StartTime) <= 60
| project StartTime, EndTime, DeviceName, InitiatingProcessAccountName,
          InitiatingProcessFileName, InitiatingProcessId,
          InitiatingProcessCommandLine, DistinctFiles, SamplePaths
| order by StartTime desc
