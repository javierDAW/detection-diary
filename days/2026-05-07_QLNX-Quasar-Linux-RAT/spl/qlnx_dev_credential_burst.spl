; Title:        QLNX — Burst of developer-credential file reads by a single process
; Id:           92b24864-d5f9-4fbd-98e2-6efe94fa8e96
; MITRE:        T1552.001, T1083, T1555.005
; Reference:    https://www.trendmicro.com/en_us/research/26/e/quasar-linux-qlnx-a-silent-foothold-in-the-software-supply-chain.html
; Author:       Jarmi
; Date:         2026-05-07
; Tested on:    Splunk — auditd (with -w on the credential paths) or
;               sysmon-for-linux FileRead events (sourcetype=Sysmon:Linux).
; FP notes:     Filter known dev tooling (gh, aws, kubectl, terraform, npm,
;               pip, yarn, pnpm, cargo, go, helm, vault). The high-fidelity
;               anomaly is a generic shell or interpreter (bash, sh, dash,
;               zsh, python3, perl, tar, find) hitting >=3 distinct
;               sensitive paths inside 60s.
;
; Logic:        Bin events into 60-second windows per process; alert on
;               distinct credential paths >= 3 from outside the dev-tool
;               allowlist.

index=os (sourcetype="Sysmon:Linux" OR sourcetype="linux:audit")
  ("/.npmrc" OR "/.pypirc" OR "/.git-credentials" OR "/.aws/credentials"
   OR "/.kube/config" OR "/.docker/config.json" OR "/.vault-token"
   OR "/.terraform.d/credentials.tfrc.json" OR "/.config/gh/hosts.yml"
   OR "/.netrc" OR "/.ssh/id_rsa" OR "/.ssh/id_ed25519")
| eval bucket=floor(_time/60)*60
| where NOT match(process_name, "^(gh|aws|gcloud|az|kubectl|docker|vault|terraform|ansible|ansible-playbook|helm|yarn|pnpm|npm|pip|pip3|poetry|cargo|go|code|code-server)$")
| stats dc(file_path) as cred_paths_seen
        values(file_path) as paths
        first(_time) as first last(_time) as last
        by host, process_id, process_name, bucket
| where cred_paths_seen >= 3
| sort 0 - cred_paths_seen, last
