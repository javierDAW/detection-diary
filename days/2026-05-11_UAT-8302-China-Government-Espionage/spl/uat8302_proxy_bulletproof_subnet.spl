; Title:        UAT-8302 outbound proxy or VPN to bulletproof subnet
; Id:           be164342-13a5-4e7d-b68c-d3d91d2c5b09
; MITRE:        T1090.001, T1090.002, T1572
; Reference:    https://blog.talosintelligence.com/uat-8302/
; Author:       Jarmi
; Date:         2026-05-11
; Tested on:    Splunk — Sysmon EID 3 (sourcetype=XmlWinEventLog:Microsoft-Windows-Sysmon/Operational)
; FP notes:     Approved corporate VPN may use SoftEther; baseline by user and host before alerting.

index=windows EventCode=3 sourcetype="XmlWinEventLog:Microsoft-Windows-Sysmon/Operational"
| eval Image_l=lower(Image)
| search (Image_l="*wagent.exe" OR Image_l="*\\mmc.exe" OR Image_l="*\\ag531.exe"
          OR Image_l="*stowaway*" OR Image_l="*anyproxy*" OR Image_l="*\\any.exe"
          OR Image_l="*communicator.exe")
       OR DestinationIp IN ("85.209.156.3","45.135.135.100","45.140.168.62",
                            "88.151.195.133","156.238.224.82","185.238.189.41",
                            "103.27.108.55","38.54.32.244")
| stats count min(_time) as first_seen max(_time) as last_seen
        values(DestinationIp) as dst_ips values(DestinationPort) as dst_ports
        values(Image) as procs by host, user
| sort - count
