// Title: Credential File Read by Node Process in AI Agent Lineage (Agentjacking)
// Id: 34782315-f9a8-493e-b78e-a5e8e10cfbd3
// MITRE: T1552.001 (Unsecured Credentials: Credentials In Files)
// Reference: https://tenetsecurity.ai/blog/agentjacking-coding-agents-with-fake-sentry-errors/
// Author: Jarmi
// Date: 2026-06-20
// Tested on: Defender XDR (DeviceFileEvents + DeviceProcessEvents)
// FP notes: Legitimate .npmrc reads by node during package install are common.
//   High-fidelity when the reading process's grandparent is an AI agent AND
//   the file is ~/.aws/credentials, ~/.docker/config.json, or ~/.ssh/id_*.
//   Correlate with npx --yes spawn (kql_npx_agent_spawn_xdr.kql) on same host
//   within 120s for near-zero FP alert.

let AIAgentProcesses = dynamic([
    "claude.exe", "cursor.exe", "windsurf.exe", "codex.exe", "continue.exe",
    "claude", "cursor", "windsurf", "codex"
]);
let CredentialPaths = dynamic([
    ".aws\\config", ".aws\\credentials",
    ".npmrc",
    ".docker\\config.json",
    ".ssh\\id_rsa", ".ssh\\id_ed25519", ".ssh\\id_ecdsa",
    ".config\\gh\\hosts.yml",
    ".kube\\config"
]);
let LookbackWindow = 7d;
// Find node/npx file read events targeting credential files
let CredReads = DeviceFileEvents
| where Timestamp > ago(LookbackWindow)
| where ActionType in ("FileRead", "FileAccessed")
| where InitiatingProcessFileName in~ ("node.exe", "node", "npx.cmd", "npx")
| where FolderPath has_any (CredentialPaths)
    or FileName in~ (".npmrc", "config.json", "credentials", "config")
| project
    ReadTimestamp = Timestamp,
    DeviceId,
    DeviceName,
    AccountName,
    CredFile = FolderPath,
    NodePID = InitiatingProcessId,
    NodeParentPID = InitiatingProcessParentId,
    NodeParent = InitiatingProcessParentFileName;
// Find AI agent processes that are ancestors
let AgentAncestors = DeviceProcessEvents
| where Timestamp > ago(LookbackWindow)
| where FileName in~ (AIAgentProcesses)
| project
    AgentTimestamp = Timestamp,
    DeviceId,
    AgentPID = ProcessId,
    AgentName = FileName;
// Correlate: find cases where node's parent chain includes an AI agent
CredReads
| join kind=inner (AgentAncestors) on DeviceId
| where NodeParentPID == AgentPID
    or NodeParent in~ (AIAgentProcesses)
| where ReadTimestamp >= AgentTimestamp
| project
    ReadTimestamp,
    DeviceName,
    AccountName,
    AgentName,
    CredFile,
    AgentTimestamp
| order by ReadTimestamp desc
