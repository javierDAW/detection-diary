# Suricata 7.x — First VPN Service (Operation Saffron) network anchors
# Author: Jarmi
# Date:   2026-05-24
# References:
#   https://www.ic3.gov/CSA/2026/260521.pdf
#   https://www.europol.europa.eu/media-press/newsroom/news/cybercriminal-vpn-used-ransomware-actors-dismantled-in-global-crackdown
#   https://thehackernews.com/2026/05/first-vpn-dismantled-in-global-takedown.html
# Notes:
#   - $HOME_NET is expected to be the corporate IPv4 ranges.
#   - The IP-egress rule uses an inline IP set; for large environments,
#     replace with an iprep / iprep-categories file populated from the FBI list
#     so that the dataset is maintainable without rule rewrites.
#   - sid range 8230001..8230008 reserved for this case.

# DNS — corporate endpoint resolving any seized First VPN customer-facing domain
alert dns $HOME_NET any -> any any (msg:"FIRSTVPN Customer endpoint DNS query for seized First VPN domain 1vpns.com"; dns.query; content:"1vpns.com"; nocase; sid:8230001; rev:1; classtype:bad-unknown; metadata:author Jarmi, attack T1090.003, ioc-source FBI_FLASH-20260521-001;)
alert dns $HOME_NET any -> any any (msg:"FIRSTVPN Customer endpoint DNS query for seized First VPN domain 1vpns.net"; dns.query; content:"1vpns.net"; nocase; sid:8230002; rev:1; classtype:bad-unknown; metadata:author Jarmi, attack T1090.003;)
alert dns $HOME_NET any -> any any (msg:"FIRSTVPN Customer endpoint DNS query for seized First VPN domain 1vpns.org"; dns.query; content:"1vpns.org"; nocase; sid:8230003; rev:1; classtype:bad-unknown; metadata:author Jarmi, attack T1090.003;)
alert dns $HOME_NET any -> any any (msg:"FIRSTVPN Customer endpoint DNS query for seized First VPN Jabber server 1jabber.com"; dns.query; content:"1jabber.com"; nocase; sid:8230004; rev:1; classtype:bad-unknown; metadata:author Jarmi, attack T1090.003;)

# TLS SNI — corporate endpoint reaching any seized First VPN customer-facing domain
alert tls $HOME_NET any -> any 443 (msg:"FIRSTVPN TLS SNI to seized First VPN domain (any of 1vpns.com|.net|.org)"; tls.sni; pcre:"/^1vpns\.(com|net|org)$/i"; sid:8230005; rev:1; classtype:bad-unknown; metadata:author Jarmi, attack T1090.003;)

# HTTP host — corporate endpoint reaching seized First VPN web (cleartext fallback / legacy clients)
alert http $HOME_NET any -> any any (msg:"FIRSTVPN HTTP Host header to seized First VPN domain"; http.host; pcre:"/^1vpns\.(com|net|org)$|^1jabber\.com$/i"; sid:8230006; rev:1; classtype:bad-unknown; metadata:author Jarmi, attack T1090.003;)

# IP egress — corporate endpoint connecting to any current First VPN exit node (FBI list)
alert ip $HOME_NET any -> [92.223.66.103,5.181.234.59,92.38.148.58,92.38.180.39,195.206.107.203,178.175.139.203,37.120.143.203,91.232.29.114,86.105.25.219,134.255.210.160,190.97.163.88,193.106.31.98,82.146.50.52,185.247.71.107,51.79.208.134,92.38.162.4,77.246.157.26,54.37.200.68,185.253.98.243,51.79.111.220,188.92.78.242,51.75.34.158,46.105.79.45,92.38.186.86,82.202.160.36,193.239.86.19,139.99.255.144,91.193.5.91,91.132.139.67,95.213.164.12,89.38.224.3,77.83.247.81,152.89.162.139] any (msg:"FIRSTVPN Outbound IP egress to known First VPN current exit node (FBI list May 2026)"; sid:8230007; rev:1; classtype:bad-unknown; metadata:author Jarmi, attack T1090.003, ioc-source FBI_FLASH-20260521-001;)

# IP ingress — inbound from a current First VPN exit node toward the public-facing perimeter (auth services, web, RDP, SSH)
alert ip [92.223.66.103,5.181.234.59,92.38.148.58,92.38.180.39,195.206.107.203,178.175.139.203,37.120.143.203,91.232.29.114,86.105.25.219,134.255.210.160,190.97.163.88,193.106.31.98,82.146.50.52,185.247.71.107,51.79.208.134,92.38.162.4,77.246.157.26,54.37.200.68,185.253.98.243,51.79.111.220,188.92.78.242,51.75.34.158,46.105.79.45,92.38.186.86,82.202.160.36,193.239.86.19,139.99.255.144,91.193.5.91,91.132.139.67,95.213.164.12,89.38.224.3,77.83.247.81,152.89.162.139] any -> $HOME_NET [22,443,3389,8443] (msg:"FIRSTVPN Inbound auth-service traffic from known First VPN current exit node (FBI list May 2026)"; flow:to_server; sid:8230008; rev:1; classtype:bad-unknown; metadata:author Jarmi, attack T1133, attack T1110, ioc-source FBI_FLASH-20260521-001;)
