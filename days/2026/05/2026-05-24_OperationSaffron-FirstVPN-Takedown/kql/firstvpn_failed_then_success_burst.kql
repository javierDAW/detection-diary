// Title:        Failed-then-success authentication burst from a known First VPN exit node
// Id:           c5a02f10-6d7a-41bc-bda0-cd30e4c0ca1c
// MITRE:        T1110, T1110.003, T1078, T1078.004, T1090.003
// Reference:    https://www.ic3.gov/CSA/2026/260521.pdf
// Author:       Jarmi
// Date:         2026-05-24
// Tested on:    Sentinel — SigninLogs (Entra ID)
// FP notes:     Real user behind a corporate roaming proxy that shares an IP with the
//               historical (post-rotation) set; rare. Penetration test mid-window;
//               correlate with engagement records.

let firstvpn_current_iocs = datatable(ip:string)[
    "92.223.66.103","5.181.234.59","92.38.148.58","92.38.180.39",
    "195.206.107.203","178.175.139.203","37.120.143.203","91.232.29.114",
    "86.105.25.219","134.255.210.160","190.97.163.88","193.106.31.98",
    "82.146.50.52","185.247.71.107","51.79.208.134","92.38.162.4",
    "77.246.157.26","54.37.200.68","185.253.98.243","51.79.111.220",
    "188.92.78.242","51.75.34.158","46.105.79.45","92.38.186.86",
    "82.202.160.36","193.239.86.19","139.99.255.144","91.193.5.91",
    "91.132.139.67","95.213.164.12","89.38.224.3","77.83.247.81",
    "152.89.162.139"
];
let window = 24h;
let failed_bursts =
    SigninLogs
    | where TimeGenerated > ago(730d)
    | where ResultType != "0"
    | where IPAddress in (firstvpn_current_iocs)
    | summarize FailedAttempts = count(),
                FirstFailure = min(TimeGenerated),
                LastFailure = max(TimeGenerated)
        by UserPrincipalName, IPAddress, bin(TimeGenerated, window)
    | where FailedAttempts >= 5;
let successes =
    SigninLogs
    | where TimeGenerated > ago(730d)
    | where ResultType == "0"
    | where IPAddress in (firstvpn_current_iocs)
    | project UserPrincipalName, IPAddress, SuccessTime = TimeGenerated,
              AppDisplayName, ResourceDisplayName;
failed_bursts
| join kind=inner (successes) on UserPrincipalName, IPAddress
| where SuccessTime between (FirstFailure .. (LastFailure + window))
| project FirstFailure, LastFailure, SuccessTime, UserPrincipalName, IPAddress,
          FailedAttempts, AppDisplayName, ResourceDisplayName
| order by SuccessTime asc
