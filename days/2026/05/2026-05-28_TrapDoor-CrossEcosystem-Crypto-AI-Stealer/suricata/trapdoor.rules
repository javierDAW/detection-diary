# Suricata 7.x rules — TrapDoor cross-ecosystem crypto / AI-developer stealer
# Author:   Jarmi
# Date:     2026-05-28
# Family:   TrapDoor (Socket-tracked, unattributed e-crime cluster)
# Reference:
#   https://socket.dev/blog/trapdoor-crypto-stealer-npm-pypi-crates
#   https://thehackernews.com/2026/05/trapdoor-supply-chain-attack-spreads.html
#
# Coverage anchors:
#   - DNS query for the attacker GitHub Pages host (single-event anchor).
#   - TLS SNI to the attacker GitHub Pages host.
#   - HTTP host header to the attacker GitHub Pages host (fallback for older
#     egress paths that downgrade to clear HTTP for diagnostic reasons).
#   - HTTP request to gist.githubusercontent.com paired with a Rust / Cargo
#     User-Agent ("reqwest", "cargo") — covers the Crates.io build.rs exfil
#     vector to GitHub Gists.
#   - HTTP request user-agent matching node / npm / cargo / python toolchain
#     User-Agents pulling /defi-security-best-practices/ path (campaign-marker
#     URI).
#
# Note on User-Agent anchors: TrapDoor reuses the standard library UAs of node
# (node-fetch / undici), python (python-requests/urllib), and rust (reqwest);
# detection is anchored on the URI + host, not on the UA alone, to avoid FPs
# against legitimate package downloads.

alert dns $HOME_NET any -> any any (msg:"PROF-CIBER TrapDoor: DNS query for ddjidd564.github.io (campaign payload host)"; dns.query; content:"ddjidd564.github.io"; nocase; classtype:trojan-activity; sid:8260001; rev:1;)

alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"PROF-CIBER TrapDoor: TLS SNI to ddjidd564.github.io"; tls.sni; content:"ddjidd564.github.io"; nocase; classtype:trojan-activity; sid:8260002; rev:1;)

alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"PROF-CIBER TrapDoor: HTTP Host ddjidd564.github.io"; flow:established,to_server; http.host; content:"ddjidd564.github.io"; nocase; classtype:trojan-activity; sid:8260003; rev:1;)

alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"PROF-CIBER TrapDoor: HTTP GET defi-security-best-practices payload URI"; flow:established,to_server; http.method; content:"GET"; http.uri; content:"/defi-security-best-practices/"; nocase; classtype:trojan-activity; sid:8260004; rev:1;)

alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"PROF-CIBER TrapDoor: HTTP request from reqwest UA to gist.githubusercontent.com (Crates build.rs exfil)"; flow:established,to_server; http.host; content:"gist.githubusercontent.com"; nocase; http.user_agent; content:"reqwest"; nocase; classtype:trojan-activity; sid:8260005; rev:1;)

alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"PROF-CIBER TrapDoor: HTTP request carrying campaign marker P-2024-001"; flow:established,to_server; http.request_body; content:"P-2024-001"; nocase; classtype:trojan-activity; sid:8260006; rev:1;)
