# UAT-7810 (LapDogs ORB) - relay-node C2/infrastructure network detection
# Author: Jarmi
# Date:   2026-07-13
# Reference: https://blog.talosintelligence.com/uat-7810/
# Notes: UAT-7810 builds Operational Relay Box networks from compromised SOHO/edge
#        devices. Detection anchors: (1) the self-signed TLS cert identity (subject
#        CN=exploit / O=exploit) served on the operator relay servers - a DURABLE
#        fingerprint that survives IP rotation; (2) payload staging over HTTP on the
#        non-standard ports 8088/2222; (3) the embedded Chrome/122 decoy User-Agent from
#        an embedded device; (4) a reference-anchor rule listing the four documented
#        VPS IPs (these DECAY - treat as hunting leads, not a permanent blocklist).
#        The port-99 relay traffic is TLS, so it is matched via cert fields, not payload.
#        SIDs 2026071301-2026071305, rev:1. No custom variables.

# 1) UAT-7810 self-signed TLS cert subject on relay/staging server (CN=exploit)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"UAT-7810 ORB - self-signed TLS cert subject CN=exploit (relay node)"; flow:established,to_server; tls.cert_subject; content:"CN=exploit"; nocase; classtype:trojan-activity; reference:url,blog.talosintelligence.com/uat-7810/; sid:2026071301; rev:1;)

# 2) UAT-7810 TLS cert organization field O=exploit (corroborating the exploit-themed DN)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"UAT-7810 ORB - TLS cert subject O=exploit/OU=exploit"; flow:established,to_server; tls.cert_subject; content:"O=exploit"; nocase; classtype:trojan-activity; reference:url,blog.talosintelligence.com/uat-7810/; sid:2026071302; rev:1;)

# 3) DOGLEASH payload staging fetch over HTTP on non-standard ports 8088/2222
alert http $HOME_NET any -> $EXTERNAL_NET [8088,2222] (msg:"UAT-7810 ORB - HTTP payload fetch on non-standard staging port (8088/2222)"; flow:established,to_server; http.method; content:"GET"; http.user_agent; content:"Wget"; nocase; classtype:trojan-activity; reference:url,blog.talosintelligence.com/uat-7810/; sid:2026071303; rev:1;)

# 4) LONGLEASH embedded Chrome/122 decoy User-Agent to a non-standard port from HOME_NET
alert http $HOME_NET any -> $EXTERNAL_NET [99,8088,2222] (msg:"UAT-7810 ORB - Chrome/122 decoy User-Agent to non-standard C2 port"; flow:established,to_server; http.user_agent; content:"Chrome/122.0.6261.95 Safari/537.36"; classtype:trojan-activity; reference:url,blog.talosintelligence.com/uat-7810/; sid:2026071304; rev:1;)

# 5) REFERENCE ANCHOR - documented UAT-7810 VPS IPs (DECAY; verify freshness, not a permanent blocklist)
alert ip $HOME_NET any -> [194.233.92.26,217.15.160.247,217.15.164.147,95.182.100.231] any (msg:"UAT-7810 ORB - connection to documented VPS infra (reference anchor, verify freshness)"; flow:to_server; classtype:trojan-activity; reference:url,blog.talosintelligence.com/uat-7810/; sid:2026071305; rev:1;)
