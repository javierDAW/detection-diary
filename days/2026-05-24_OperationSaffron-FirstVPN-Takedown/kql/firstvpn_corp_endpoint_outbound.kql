// Title:        Managed corporate endpoint outbound connection to a known First VPN exit node
// Id:           062676d6-b18c-44fe-a9e6-3b6d59b2c1df
// MITRE:        T1090, T1090.003, T1572, T1571, T1078
// Reference:    https://www.ic3.gov/CSA/2026/260521.pdf
// Reference:    https://thehackernews.com/2026/05/first-vpn-dismantled-in-global-takedown.html
// Author:       Jarmi
// Date:         2026-05-24
// Tested on:    Defender XDR — DeviceNetworkEvents
// FP notes:     SOC analyst manually validating an IOC by establishing a deliberate
//               connection from a workstation; whitelist analyst hosts. Threat-intel
//               platforms that auto-pivot to seized infrastructure; exclude TI infrastructure.

let firstvpn_current_iocs = datatable(ip:string)[
    "92.223.66.103","5.181.234.59","92.38.148.58","92.38.180.39",
    "195.206.107.203","178.175.139.203","37.120.143.203","91.232.29.114",
    "86.105.25.219","134.255.210.160","190.97.163.88","193.106.31.98",
    "82.146.50.52","185.247.71.107","51.79.208.134","92.38.162.4",
    "77.246.157.26","54.37.200.68","185.253.98.243","51.79.111.220",
    "188.92.78.242","51.75.34.158","46.105.79.45","92.38.186.86",
    "82.202.160.36","193.239.86.19","139.99.255.144","91.193.5.91",
    "91.132.139.67","95.213.164.12","89.38.224.3","77.83.247.81",
    "152.89.162.139"
];
DeviceNetworkEvents
| where Timestamp > ago(180d)
| where ActionType in ("ConnectionSuccess", "ConnectionAttempt")
| where RemoteIP in (firstvpn_current_iocs)
| project Timestamp, DeviceName, InitiatingProcessAccountName,
          InitiatingProcessFileName, InitiatingProcessCommandLine,
          RemoteIP, RemotePort, Protocol, LocalIP
| order by Timestamp asc
