// =============================================================================
// adx_tests.kql — regression tests for the detection-diary KQL queries
// Author:    Jarmi
// Date:      2026-05-08
// Purpose:   For every KQL rule in days/*/kql/, run a wrapped version against
//            the synthetic data seeded by adx_seed.kql and assert the expected
//            hit count.
// Usage:
//   1. Bootstrap (adx_bootstrap.kql) and seed (adx_seed.kql) must already be done.
//   2. Paste this whole file in an ADX query window.
//   3. Click anywhere in the script and Run. The whole file is one query —
//      no .execute database script wrapper is needed because there are no
//      control commands here, only data queries.
//   4. The final `union` returns a table with one row per rule and a
//      `status` column = "PASS" or "FAIL".
// =============================================================================

let t_day01 =
    DeviceNetworkEvents
    | where Timestamp > ago(7d)
    | where Protocol == "Tcp"
    | where RemotePort in (443, 8443) and isempty(RemoteUrl)
    | summarize beacons = count() by DeviceId, RemoteIP, InitiatingProcessFileName
    | where beacons >= 3
    | summarize hits = count();
let t_day02 =
    GitHubAuditLogs
    | where TimeGenerated > ago(7d)
    | where action_s == "repo.create"
    | where repository_visibility_s == "public"
    | where repo_s contains "Shai-Hulud"
    | summarize hits = count();
let t_day03 =
    Syslog
    | where TimeGenerated > ago(7d) and Computer == "asa-edge-01"
    | extend large = extract(@"size=(\d+)", 1, SyslogMessage, typeof(long))
    | summarize reboots = countif(SyslogMessage has "Reload"),
                big_posts = countif(large > 8192) by Computer
    | where reboots >= 1 and big_posts >= 1
    | summarize hits = count();
let t_day04 =
    DeviceProcessEvents
    | where Timestamp > ago(7d)
    | where FileName == "taskkill.exe"
    | where ProcessCommandLine has_any ("sqlservr","oracle","excel","winword","outlook","firefox","thunderbird")
    | summarize unique_kills = dcount(ProcessCommandLine) by DeviceId, InitiatingProcessFileName, bin(Timestamp, 1m)
    | where unique_kills >= 5
    | summarize hits = count();
let t_day06 =
    DeviceNetworkEvents
    | where Timestamp > ago(7d)
    | where InitiatingProcessFileName in~ ("Studio5000.exe","RSLogix5000.exe","RSLinx.exe")
    | where RemotePort in (44818, 2222, 502)
    | where not(ipv4_is_in_range(RemoteIP, "10.0.0.0/8"))
            and not(ipv4_is_in_range(RemoteIP, "172.16.0.0/12"))
            and not(ipv4_is_in_range(RemoteIP, "192.168.0.0/16"))
    | summarize hits = count();
let t_day07a =
    DeviceFileEvents
    | where Timestamp > ago(7d)
    | where FileName endswith ".DMP" or FileName endswith ".dmp"
    | where FileName has "lsass" or TargetFilename has "lsass"
    | where InitiatingProcessFileName =~ "Taskmgr.exe"
    | summarize hits = count();
let t_day07b =
    SecurityEvent
    | where TimeGenerated > ago(7d) and EventID == 4769
    | summarize tickets = count() by Computer, bin(TimeGenerated, 1m)
    | where tickets >= 4
    | summarize hits = count();
let t_day08a =
    Syslog
    | where TimeGenerated > ago(7d) and Computer == "sonicwall-01"
    | where SyslogMessage has "SSL VPN user logged in"
    | extend src_ip = extract(@"src=(\d+\.\d+\.\d+\.\d+)", 1, SyslogMessage)
    | where isnotempty(src_ip)
    | summarize hits = count();
let t_day08b =
    DeviceNetworkEvents
    | where Timestamp > ago(7d) and RemotePort == 445
    | where InitiatingProcessFileName endswith ".py" or InitiatingProcessFileName has_any ("wmiexec","smbexec","psexec")
    | summarize hosts = dcount(RemoteIP) by DeviceId, InitiatingProcessFileName, bin(Timestamp, 1m)
    | where hosts >= 5
    | summarize hits = count();
let t_day09a_signin = SigninLogs   | where TimeGenerated > ago(7d) | project STime=TimeGenerated, UPN=UserPrincipalName, IP=IPAddress;
let t_day09a_audit  = AuditLogs    | where TimeGenerated > ago(7d) and OperationName == "Add device" | project ATime=TimeGenerated, AIdentity=Identity;
let t_day09a_inbox  = OfficeActivity
    | where TimeGenerated > ago(7d) and Operation == "New-InboxRule"
    | extend rname = tostring(parse_json(tostring(Parameters)).Name)
    | where strlen(rname) <= 1
    | project OTime=TimeGenerated, OUid=UserId;
let t_day09a =
    t_day09a_signin
    | join kind=inner (t_day09a_audit) on $left.UPN == $right.AIdentity
    | join kind=inner (t_day09a_inbox) on $left.UPN == $right.OUid
    | distinct UPN
    | summarize hits = count();
let t_day09b =
    EmailUrlInfo
    | where Timestamp > ago(7d)
    | where UrlDomain has_any ("acceptable-use-policy","compliance-protectionoutlook")
    | join kind=inner (
        EmailAttachmentInfo
        | where Timestamp > ago(7d) and FileType == "pdf"
    ) on NetworkMessageId
    | distinct NetworkMessageId
    | summarize hits = count();
let t_day10a =
    DeviceFileEvents
    | where Timestamp > ago(7d)
    | where FolderPath == "/etc/" and FileName == "ld.so.preload"
    | where ActionType == "FileModified"
    | summarize hits = count();
let t_day10b =
    DeviceFileEvents
    | where Timestamp > ago(7d)
    | where FileName in~ (".npmrc","credentials","id_rsa",".git-credentials",".pypirc",".vault-token")
            or FolderPath has_any ("/.aws/","/.kube/","/.docker/")
    | summarize files = dcount(FileName), first_t=min(Timestamp), last_t=max(Timestamp)
                by DeviceId, InitiatingProcessId, InitiatingProcessFileName
    | where files >= 3 and datetime_diff('second', last_t, first_t) <= 60
    | summarize hits = count();
let t_day10c =
    DeviceNetworkEvents
    | where Timestamp > ago(7d)
    | where RemoteUrl has "ip-api.com" or RemoteIP startswith "208.95.112."
    | summarize hits = count();
let t_day10d =
    DeviceFileEvents
    | where Timestamp > ago(7d)
    | where FolderPath == "/tmp/" and FileName matches regex @"^\.X[0-9a-f]{8}-lock$"
    | summarize hits = count();
let t_day11a =
    DeviceNetworkEvents
    | where Timestamp > ago(7d)
    | where InitiatingProcessFileName in~ ("node.exe","node","ts-node")
    | where RemoteIP matches regex @"^\d+\.\d+\.\d+\.\d+$"
    | where not(ipv4_is_in_range(RemoteIP, "10.0.0.0/8"))
            and not(ipv4_is_in_range(RemoteIP, "172.16.0.0/12"))
            and not(ipv4_is_in_range(RemoteIP, "192.168.0.0/16"))
    | summarize hits = count();
let t_day11b =
    DeviceFileEvents
    | where Timestamp > ago(7d)
    | where InitiatingProcessFileName in~ ("node.exe","node","ts-node")
    | where FolderPath has_any (@"\.foundry\", @"\.brownie\", @"\app\", @"\.ssh\")
            or FileName has_any (".env",".env.local",".env.production","foundry.toml","hardhat.config.js")
    | summarize files = dcount(strcat(FolderPath, FileName))
                by DeviceId, InitiatingProcessId, InitiatingProcessFileName, bin(Timestamp, 5m)
    | where files >= 3
    | summarize hits = count();
let t_day12_phoneDb =
    DeviceFileEvents
    | where Timestamp > ago(7d)
    | where FileName startswith "PhoneExperiences" and FileName endswith ".db"
    | where FolderPath has @"\Microsoft.YourPhone_8wekyb3d8bbwe\LocalState\"
    | where InitiatingProcessFolderPath !has @"\Microsoft.YourPhone_8wekyb3d8bbwe\"
            and InitiatingProcessFileName !in~ ("YourPhone.exe","PhoneExperienceHost.exe")
    | project DbTime=Timestamp, DeviceId;
let t_day12_beacon =
    DeviceNetworkEvents
    | where Timestamp > ago(7d)
    | where RemoteUrl has "hellohiall.workers.dev" or RemoteIP == "185.196.10.136"
    | project NetTime=Timestamp, DeviceId;
let t_day12 =
    t_day12_phoneDb
    | join kind=inner (t_day12_beacon) on DeviceId
    | where abs(datetime_diff('minute', DbTime, NetTime)) <= 30
    | distinct DeviceId
    | summarize hits = count();
union
    (t_day01  | extend rule = "day01_systembc_tcp_beacon",          expected = 1),
    (t_day02  | extend rule = "day02_shai_hulud_repo_create",        expected = 1),
    (t_day03  | extend rule = "day03_asa_reboot_webvpn_large",       expected = 1),
    (t_day04  | extend rule = "day04_vect_mass_process_kill",        expected = 1),
    (t_day06  | extend rule = "day06_bauxite_studio5000_egress",     expected = 1),
    (t_day07a | extend rule = "day07_poland_lsass_dump_taskmgr",     expected = 1),
    (t_day07b | extend rule = "day07_poland_rubeus_s4u_burst",       expected = 1),
    (t_day08a | extend rule = "day08_akira_sonicwall_vpn_login",     expected = 1),
    (t_day08b | extend rule = "day08_akira_impacket_smb_burst",      expected = 1),
    (t_day09a | extend rule = "day09_aitm_chain_correlation",        expected = 1),
    (t_day09b | extend rule = "day09_pdf_lure_first_seen_domain",    expected = 1),
    (t_day10a | extend rule = "day10_qlnx_ld_preload_modification",  expected = 1),
    (t_day10b | extend rule = "day10_qlnx_credential_burst",         expected = 1),
    (t_day10c | extend rule = "day10_qlnx_ipapi_recon",              expected = 1),
    (t_day10d | extend rule = "day10_qlnx_x11_lock_drop",            expected = 1),
    (t_day11a | extend rule = "day11_evmdefi_node_ipv4_first_seen",  expected = 1),
    (t_day11b | extend rule = "day11_evmdefi_dev_cred_burst",        expected = 1),
    (t_day12  | extend rule = "day12_cloudz_pheno_phone_db_workers", expected = 1)
| project rule, expected, hits, status = iff(hits == expected, "PASS", "FAIL")
| sort by status asc, rule asc
