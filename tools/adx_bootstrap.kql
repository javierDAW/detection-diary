// =============================================================================
// adx_bootstrap.kql — Azure Data Explorer free-cluster schema bootstrap
// Author:    Jarmi
// Date:      2026-05-10
// Purpose:   Provision the Defender XDR + Sentinel + custom tables that every
//            KQL rule in detection-diary/days/*/kql/ references, so the
//            operator can replay every rule in a personal ADX free cluster
//            without an Azure subscription. Same Kusto engine as Sentinel /
//            Defender XDR.
//
// Design:    The schemas below are a *practical superset* of every column
//            referenced by any rule in the repo as of the date above. They
//            are aligned to the column names the rules actually use (which
//            mirror Microsoft Defender XDR Advanced Hunting / Sentinel
//            naming). When a rule and the original Microsoft schema disagree
//            on naming, this bootstrap prefers the rule's name so the rule
//            runs unchanged against this cluster.
//
// Usage:
//   1. Create the free cluster at https://dataexplorer.azure.com
//   2. Open a Kusto query window pointing at your free database
//      (default name 'mykustodb').
//   3. Paste the entire content of this file.
//   4. Place the cursor anywhere inside the ".execute database script <| ..."
//      block and press Shift+Enter (or click Run). The whole script runs
//      as ONE management operation.
//   5. Then place the cursor on the verification query at the bottom and
//      press Shift+Enter to confirm the tables exist.
//   6. Continue with tools/adx_seed.kql to populate synthetic rows, then
//      tools/adx_tests.kql to validate every rule.
//
// Why ".execute database script"?
//   The ADX Web UI runs ONE batch per Shift+Enter. Multiple bare control
//   commands separated by single newlines are parsed as one statement and
//   fail with "A recognition error occurred". The .execute database script
//   wrapper is the official way to run an atomic multi-command script.
// =============================================================================

.execute database script with (ContinueOnErrors = false, ThrowOnErrors = true) <|
    //
    // ---- Reset (idempotent) -------------------------------------------------
    //
    .drop table DeviceFileEvents             ifexists
    .drop table DeviceProcessEvents          ifexists
    .drop table DeviceNetworkEvents          ifexists
    .drop table DeviceLogonEvents            ifexists
    .drop table DeviceImageLoadEvents        ifexists
    .drop table DeviceRegistryEvents         ifexists
    .drop table DeviceInfo                   ifexists
    .drop table DeviceEvents                 ifexists
    .drop table DeviceTvmSoftwareInventory   ifexists
    .drop table SecurityEvent                ifexists
    .drop table Syslog                       ifexists
    .drop table AuditLogs                    ifexists
    .drop table SigninLogs                   ifexists
    .drop table CloudAppEvents               ifexists
    .drop table OfficeActivity               ifexists
    .drop table EmailUrlInfo                 ifexists
    .drop table EmailAttachmentInfo          ifexists
    .drop table UrlClickEvents               ifexists
    .drop table GitHubAuditLogs              ifexists
    .drop table AzureDiagnostics             ifexists
    .drop table W3CIISLog                    ifexists
    .drop table CommonSecurityLog            ifexists
    .drop table AsaWebVpnAccessLogs_CL       ifexists
    //
    // =========================================================================
    // Defender XDR — Device-side hunting tables
    // =========================================================================
    //
    // DeviceFileEvents — used by Day 4 (LSASS dump), Day 6 (BAUXITE),
    // Day 7 (Poland Wiper), Day 10 (QLNX, four rules), Day 11 (EVM-DeFi cred
    // burst), Day 12 (CloudZ phone DB).
    //
    .create table DeviceFileEvents (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        DeviceOSPlatform:string,
        ActionType:string,
        FileName:string,
        FolderPath:string,
        SHA256:string,
        SHA1:string,
        MD5:string,
        FileSize:long,
        InitiatingProcessId:long,
        InitiatingProcessFileName:string,
        InitiatingProcessSHA256:string,
        InitiatingProcessFolderPath:string,
        InitiatingProcessAccountName:string,
        InitiatingProcessAccountDomain:string,
        InitiatingProcessCommandLine:string,
        InitiatingProcessParentFileName:string,
        InitiatingProcessParentId:long,
        RequestProtocol:string,
        TargetFilename:string)
    //
    // DeviceProcessEvents — used by Day 1 (TheGentlemen baseline), Day 4 (VECT),
    // Day 7 (Poland Wiper), Day 8 (Akira recon), Day 11 (EVM-DeFi dev tooling).
    //
    .create table DeviceProcessEvents (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        DeviceOSPlatform:string,
        ActionType:string,
        FileName:string,
        FolderPath:string,
        SHA256:string,
        SHA1:string,
        MD5:string,
        ProcessId:long,
        ProcessCommandLine:string,
        ProcessCreationTime:datetime,
        ProcessTokenElevation:string,
        ProcessIntegrityLevel:string,
        AccountName:string,
        AccountDomain:string,
        AccountSid:string,
        InitiatingProcessId:long,
        InitiatingProcessFileName:string,
        InitiatingProcessSHA256:string,
        InitiatingProcessFolderPath:string,
        InitiatingProcessCommandLine:string,
        InitiatingProcessAccountName:string,
        InitiatingProcessAccountDomain:string,
        InitiatingProcessParentFileName:string,
        InitiatingProcessParentId:long)
    //
    // DeviceNetworkEvents — used by Days 1, 6, 8, 10, 11, 12, 14.
    //
    .create table DeviceNetworkEvents (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        DeviceOSPlatform:string,
        ActionType:string,
        RemoteIP:string,
        RemotePort:long,
        RemoteUrl:string,
        LocalIP:string,
        LocalPort:long,
        Protocol:string,
        AccountName:string,
        AccountDomain:string,
        InitiatingProcessId:long,
        InitiatingProcessFileName:string,
        InitiatingProcessSHA256:string,
        InitiatingProcessFolderPath:string,
        InitiatingProcessCommandLine:string,
        InitiatingProcessAccountName:string,
        InitiatingProcessAccountDomain:string,
        InitiatingProcessParentFileName:string,
        InitiatingProcessParentId:long)
    //
    // DeviceLogonEvents — used by Day 8 (Akira VPN logon).
    //
    .create table DeviceLogonEvents (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        ActionType:string,
        AccountName:string,
        AccountDomain:string,
        AccountSid:string,
        LogonType:string,
        Protocol:string,
        FailureReason:string,
        RemoteIP:string,
        RemoteIPType:string,
        RemoteDeviceName:string,
        InitiatingProcessFileName:string,
        InitiatingProcessId:long,
        InitiatingProcessCommandLine:string)
    //
    // DeviceImageLoadEvents — kept for future rules.
    //
    .create table DeviceImageLoadEvents (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        ActionType:string,
        FileName:string,
        FolderPath:string,
        SHA256:string,
        InitiatingProcessFileName:string,
        InitiatingProcessId:long,
        InitiatingProcessFolderPath:string)
    //
    // DeviceRegistryEvents — kept for future rules.
    //
    .create table DeviceRegistryEvents (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        ActionType:string,
        RegistryKey:string,
        RegistryValueName:string,
        RegistryValueData:string,
        InitiatingProcessFileName:string,
        InitiatingProcessId:long,
        InitiatingProcessAccountName:string)
    //
    // DeviceInfo — used by Day 14 (Mexico Water LLM API egress) to classify
    // hosts as Server vs Workstation.
    //
    .create table DeviceInfo (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        DeviceCategory:string,
        DeviceType:string,
        DeviceSubtype:string,
        OSPlatform:string,
        OSVersion:string,
        OSBuild:string,
        PublicIP:string,
        ClientVersion:string,
        IsAzureADJoined:bool,
        IsInternetFacing:bool,
        LoggedOnUsers:dynamic,
        RegistryDeviceTag:string,
        MachineGroup:string,
        ReportId:long)
    //
    // DeviceEvents — generic Defender event sink used by Android MDE.
    // Required by Day 9 (Albiriox) for NotificationListenerGranted,
    // DangerousPermissionGranted, AppInstalled, AccessibilityServiceEnabled.
    //
    .create table DeviceEvents (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        DeviceOSPlatform:string,
        ActionType:string,
        FileName:string,
        FolderPath:string,
        SHA256:string,
        AccountName:string,
        InitiatingProcessFileName:string,
        InitiatingProcessId:long,
        InitiatingProcessCommandLine:string,
        InitiatingProcessAccountName:string,
        AdditionalFields:dynamic)
    //
    // DeviceTvmSoftwareInventory — required by Day 9 (Albiriox sideload rule)
    // to gate matches to devices that have a banking / wallet app installed.
    //
    .create table DeviceTvmSoftwareInventory (
        DeviceId:string,
        DeviceName:string,
        OSPlatform:string,
        SoftwareVendor:string,
        SoftwareName:string,
        SoftwareVersion:string,
        EndOfSupportStatus:string)
    //
    // =========================================================================
    // Sentinel — Windows / Linux / Azure / Office / Email tables
    // =========================================================================
    //
    // SecurityEvent — used by Day 7 (Rubeus S4U TGS burst). Includes
    // TicketEncryptionType so the burst rule can filter on AES256/RC4.
    //
    .create table SecurityEvent (
        TimeGenerated:datetime,
        Computer:string,
        EventID:long,
        EventSourceName:string,
        Channel:string,
        Account:string,
        AccountDomain:string,
        TargetUserName:string,
        TargetDomainName:string,
        SubjectUserName:string,
        SubjectDomainName:string,
        LogonType:long,
        LogonProcessName:string,
        AuthenticationPackageName:string,
        Process:string,
        CommandLine:string,
        ParentProcessName:string,
        NewProcessName:string,
        IpAddress:string,
        IpPort:long,
        TicketEncryptionType:string,
        TicketOptions:string,
        ServiceName:string,
        EventData:dynamic)
    //
    // Syslog — used by Day 3 (FIRESTARTER ASA reboot signal).
    //
    .create table Syslog (
        TimeGenerated:datetime,
        Computer:string,
        HostName:string,
        Facility:string,
        SeverityLevel:string,
        SyslogMessage:string,
        ProcessName:string,
        ProcessID:long,
        HostIP:string,
        SourceSystem:string)
    //
    // AuditLogs — Entra ID directory audit. Used by Day 6 (PEAK H1) and
    // Day 9 (AiTM chain — Add device).
    //
    .create table AuditLogs (
        TimeGenerated:datetime,
        OperationName:string,
        Category:string,
        Result:string,
        ResultReason:string,
        ResultDescription:string,
        ResultSignature:string,
        Identity:string,
        ActivityDisplayName:string,
        InitiatedBy:dynamic,
        TargetResources:dynamic,
        AdditionalDetails:dynamic,
        CorrelationId:string)
    //
    // SigninLogs — used by Day 9 (AiTM chain — risky sign-in).
    //
    .create table SigninLogs (
        TimeGenerated:datetime,
        UserPrincipalName:string,
        UserId:string,
        UserDisplayName:string,
        AppDisplayName:string,
        ResourceDisplayName:string,
        IPAddress:string,
        Location:string,
        ResultType:string,
        ResultDescription:string,
        AuthenticationRequirement:string,
        ConditionalAccessStatus:string,
        RiskLevelDuringSignIn:string,
        RiskLevelAggregated:string,
        RiskState:string,
        AuthenticationDetails:dynamic,
        MfaDetail:dynamic,
        DeviceDetail:dynamic,
        ClientAppUsed:string,
        UserAgent:string,
        CorrelationId:string,
        SessionId:string)
    //
    // CloudAppEvents — used by Day 9 (AiTM chain — InboxRule operations).
    // Note: rules in this repo use TimeGenerated (the Sentinel-streamed name).
    //
    .create table CloudAppEvents (
        TimeGenerated:datetime,
        ActionType:string,
        Application:string,
        AccountObjectId:string,
        AccountDisplayName:string,
        AccountUpn:string,
        IPAddress:string,
        IsAnonymousProxy:bool,
        RawEventData:dynamic,
        ObjectName:string,
        ObjectType:string)
    //
    // OfficeActivity — kept for future rules (mailbox auditing).
    //
    .create table OfficeActivity (
        TimeGenerated:datetime,
        Operation:string,
        RecordType:string,
        UserId:string,
        UserKey:string,
        ClientIP:string,
        Parameters:dynamic,
        OfficeWorkload:string,
        OfficeObjectId:string,
        ResultStatus:string)
    //
    // EmailUrlInfo — used by Day 9 (firstseen attacker domain via PDF).
    //
    .create table EmailUrlInfo (
        TimeGenerated:datetime,
        NetworkMessageId:string,
        Url:string,
        UrlDomain:string,
        UrlLocation:string)
    //
    // EmailAttachmentInfo — used by Day 9 (firstseen attacker domain via PDF).
    // RecipientEmailAddress and Subject are projected by the rule.
    //
    .create table EmailAttachmentInfo (
        TimeGenerated:datetime,
        NetworkMessageId:string,
        SenderFromAddress:string,
        RecipientEmailAddress:string,
        Subject:string,
        FileName:string,
        FileType:string,
        SHA256:string,
        FileSize:long)
    //
    // UrlClickEvents — used by Day 6 (PEAK H1 — click-to-device chain) and
    // Day 9 (firstseen domain) leftouter join.
    //
    .create table UrlClickEvents (
        TimeGenerated:datetime,
        NetworkMessageId:string,
        AccountUpn:string,
        Url:string,
        ActionType:string,
        IPAddress:string,
        UrlChain:dynamic)
    //
    // GitHubAuditLogs — custom Sentinel solution. Rule uses Action / Actor /
    // AdditionalFields naming, so we expose that directly.
    //
    .create table GitHubAuditLogs (
        TimeGenerated:datetime,
        Action:string,
        Actor:string,
        Repo:string,
        Org:string,
        RepositoryVisibility:string,
        CreatedAt:datetime,
        AdditionalFields:dynamic)
    //
    // AzureDiagnostics — used by Day 2 (Nexcorium WAF X-Hacked-By header).
    //
    .create table AzureDiagnostics (
        TimeGenerated:datetime,
        ResourceProvider:string,
        ResourceType:string,
        Category:string,
        OperationName:string,
        ResourceId:string,
        properties_s:string,
        clientIp_s:string,
        host_s:string,
        requestUri_s:string)
    //
    // W3CIISLog — used by Day 2 (Nexcorium IIS branding header in UA).
    //
    .create table W3CIISLog (
        TimeGenerated:datetime,
        sSiteName:string,
        sComputerName:string,
        sIP:string,
        csMethod:string,
        csUriStem:string,
        csUriQuery:string,
        sPort:long,
        csUserName:string,
        cIP:string,
        csUserAgent:string,
        scStatus:long,
        scSubStatus:long,
        scWin32Status:long,
        timeTaken:long)
    //
    // CommonSecurityLog — used by Day 8 (SonicWall SSL VPN login via CEF).
    //
    .create table CommonSecurityLog (
        TimeGenerated:datetime,
        DeviceVendor:string,
        DeviceProduct:string,
        DeviceVersion:string,
        DeviceEventClassID:string,
        Activity:string,
        Severity:string,
        SourceUserName:string,
        SourceIP:string,
        SourcePort:long,
        DestinationIP:string,
        DestinationPort:long,
        Protocol:string,
        ApplicationProtocol:string,
        RequestURL:string,
        Message:string)
    //
    // AsaWebVpnAccessLogs_CL — custom log table referenced by Day 3 rule.
    //
    .create table AsaWebVpnAccessLogs_CL (
        TimeGenerated:datetime,
        Method_s:string,
        Uri_s:string,
        BodyBytes_d:long,
        AsaHostname_s:string,
        ClientIp_s:string,
        UserAgent_s:string,
        StatusCode_d:long)

// =============================================================================
// Verification query — run this AFTER the script block above completes.
// Place the cursor on the `.show tables` line and press Shift+Enter.
// You should see 23 tables.
// =============================================================================

.show tables | project TableName | order by TableName asc
