// =============================================================================
// adx_bootstrap.kql — Azure Data Explorer free-cluster schema bootstrap
// Author:    Jarmi
// Date:      2026-05-10
// Purpose:   Provision the Defender XDR + Sentinel + custom tables that every
//            KQL rule in detection-diary/days/*/kql/ references, so the
//            operator can replay every rule in a personal ADX free cluster
//            without an Azure subscription. Same Kusto engine as Sentinel /
//            Defender XDR.
//
// Design:    The schemas below are a *practical superset* of every column
//            referenced by any rule in the repo as of the date above. They
//            are aligned to the column names the rules actually use (which
//            mirror Microsoft Defender XDR Advanced Hunting / Sentinel
//            naming). When a rule and the original Microsoft schema disagree
//            on naming, this bootstrap prefers the rule's name so the rule
//            runs unchanged against this cluster.
//
// Usage:
//   1. Create the free cluster at https://dataexplorer.azure.com
//   2. Open a Kusto query window pointing at your free database
//      (default name 'mykustodb').
//   3. Paste the entire content of this file.
//   4. Place the cursor anywhere inside the ".execute database script <| ..."
//      block and press Shift+Enter (or click Run). The whole script runs
//      as ONE management operation.
//   5. Then place the cursor on the verification query at the bottom and
//      press Shift+Enter to confirm the tables exist.
//   6. Continue with tools/adx_seed.kql to populate synthetic rows, then
//      tools/adx_tests.kql to validate every rule.
//
// Why ".execute database script"?
//   The ADX Web UI runs ONE batch per Shift+Enter. Multiple bare control
//   commands separated by single newlines are parsed as one statement and
//   fail with "A recognition error occurred". The .execute database script
//   wrapper is the official way to run an atomic multi-command script.
// =============================================================================

.execute database script with (ContinueOnErrors = false, ThrowOnErrors = true) <|
    //
    // ---- Reset (idempotent) -------------------------------------------------
    //
    .drop table DeviceFileEvents             ifexists
    .drop table DeviceProcessEvents          ifexists
    .drop table DeviceNetworkEvents          ifexists
    .drop table DeviceLogonEvents            ifexists
    .drop table DeviceImageLoadEvents        ifexists
    .drop table DeviceRegistryEvents         ifexists
    .drop table DeviceInfo                   ifexists
    .drop table DeviceEvents                 ifexists
    .drop table DeviceTvmSoftwareInventory   ifexists
    .drop table SecurityEvent                ifexists
    .drop table Syslog                       ifexists
    .drop table AuditLogs                    ifexists
    .drop table SigninLogs                   ifexists
    .drop table CloudAppEvents               ifexists
    .drop table OfficeActivity               ifexists
    .drop table EmailUrlInfo                 ifexists
    .drop table EmailAttachmentInfo          ifexists
    .drop table UrlClickEvents               ifexists
    .drop table GitHubAuditLogs              ifexists
    .drop table AzureDiagnostics             ifexists
    .drop table W3CIISLog                    ifexists
    .drop table CommonSecurityLog            ifexists
    .drop table AsaWebVpnAccessLogs_CL       ifexists
    //
    // =========================================================================
    // Defender XDR — Device-side hunting tables
    // =========================================================================
    //
    // DeviceFileEvents — used by Day 4 (LSASS dump), Day 6 (BAUXITE),
    // Day 7 (Poland Wiper), Day 10 (QLNX, four rules), Day 11 (EVM-DeFi cred
    // burst), Day 12 (CloudZ phone DB).
    //
    .create table DeviceFileEvents (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        DeviceOSPlatform:string,
        ActionType:string,
        FileName:string,
        FolderPath:string,
        SHA256:string,
        SHA1:string,
        MD5:string,
        FileSize:long,
        InitiatingProcessId:long,
        InitiatingProcessFileName:string,
        InitiatingProcessSHA256:string,
        InitiatingProcessFolderPath:string,
        InitiatingProcessAccountName:string,
        InitiatingProcessAccountDomain:string,
        InitiatingProcessCommandLine:string,
        InitiatingProcessParentFileName:string,
        InitiatingProcessParentId:long,
        RequestProtocol:string,
        TargetFilename:string)
    //
    // DeviceProcessEvents — used by Day 1 (TheGentlemen baseline), Day 4 (VECT),
    // Day 7 (Poland Wiper), Day 8 (Akira recon), Day 11 (EVM-DeFi dev tooling).
    //
    .create table DeviceProcessEvents (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        DeviceOSPlatform:string,
        ActionType:string,
        FileName:string,
        FolderPath:string,
        SHA256:string,
        SHA1:string,
        MD5:string,
        ProcessId:long,
        ProcessCommandLine:string,
        ProcessCreationTime:datetime,
        ProcessTokenElevation:string,
        ProcessIntegrityLevel:string,
        AccountName:string,
        AccountDomain:string,
        AccountSid:string,
        InitiatingProcessId:long,
        InitiatingProcessFileName:string,
        InitiatingProcessSHA256:string,
        InitiatingProcessFolderPath:string,
        InitiatingProcessCommandLine:string,
        InitiatingProcessAccountName:string,
        InitiatingProcessAccountDomain:string,
        InitiatingProcessParentFileName:string,
        InitiatingProcessParentId:long)
    //
    // DeviceNetworkEvents — used by Days 1, 6, 8, 10, 11, 12, 14.
    //
    .create table DeviceNetworkEvents (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        DeviceOSPlatform:string,
        ActionType:string,
        RemoteIP:string,
        RemotePort:long,
        RemoteUrl:string,
        LocalIP:string,
        LocalPort:long,
        Protocol:string,
        AccountName:string,
        AccountDomain:string,
        InitiatingProcessId:long,
        InitiatingProcessFileName:string,
        InitiatingProcessSHA256:string,
        InitiatingProcessFolderPath:string,
        InitiatingProcessCommandLine:string,
        InitiatingProcessAccountName:string,
        InitiatingProcessAccountDomain:string,
        InitiatingProcessParentFileName:string,
        InitiatingProcessParentId:long)
    //
    // DeviceLogonEvents — used by Day 8 (Akira VPN logon).
    //
    .create table DeviceLogonEvents (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        ActionType:string,
        AccountName:string,
        AccountDomain:string,
        AccountSid:string,
        LogonType:string,
        Protocol:string,
        FailureReason:string,
        RemoteIP:string,
        RemoteIPType:string,
        RemoteDeviceName:string,
        InitiatingProcessFileName:string,
        InitiatingProcessId:long,
        InitiatingProcessCommandLine:string)
    //
    // DeviceImageLoadEvents — kept for future rules.
    //
    .create table DeviceImageLoadEvents (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        ActionType:string,
        FileName:string,
        FolderPath:string,
        SHA256:string,
        InitiatingProcessFileName:string,
        InitiatingProcessId:long,
        InitiatingProcessFolderPath:string)
    //
    // DeviceRegistryEvents — kept for future rules.
    //
    .create table DeviceRegistryEvents (
        Timestamp:datetime,
        DeviceId:string,
        DeviceName:string,
        ActionType:string,
        RegistryKey:string,
        RegistryValueName:string,
        RegistryValueData:string,
        InitiatingProcessFileName:string,
        InitiatingProcessId:long,
        InitiatingProcessAccountName:string)
    //
    // DeviceInfo — used by Day 14 (Mexico Water LLM API egress) to classify
    // hosts as Server vs Workstation.
    //
    .create table DeviceInfo (
        Timestamp:datetime,
        DeviceId:string,
